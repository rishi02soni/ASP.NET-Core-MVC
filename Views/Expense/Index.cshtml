@model List<ExpenseTracker.Models.Expense>

<h2>Expense Tracker</h2>

<h4>Total Expense:
₹ @ViewBag.Total
</h4>

<a asp-action="Create"
class="btn btn-primary">
Add Expense
</a>

<table class="table">

<tr>
<th>Title</th>
<th>Category</th>
<th>Amount</th>
<th>Date</th>
<th>Action</th>
</tr>

@foreach(var item in Model)
{
<tr>

<td>@item.Title</td>

<td>@item.Category</td>

<td>₹ @item.Amount</td>

<td>@item.Date.ToShortDateString()</td>

<td>

<a asp-action="Edit"
asp-route-id="@item.Id">
Edit
</a>

|

<a asp-action="Delete"
asp-route-id="@item.Id">
Delete
</a>

</td>

</tr>
}

</table>
